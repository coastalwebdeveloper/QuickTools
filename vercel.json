{
  "rewrites": [
    {
      "source": "/((?!sitemap\.xml|robots\.txt|favicon\.ico|.*\.(png|jpg|jpeg|gif|svg|css|js|json|xml)).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ]
}